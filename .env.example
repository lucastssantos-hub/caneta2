# Banco de dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/glp1_tracker?schema=public"

# NextAuth (quando adicionar autenticação)
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria"
NEXTAUTH_URL="http://localhost:3000"

# Web Push (VAPID) — gere um par com: npm run vapid
# A chave PÚBLICA precisa do prefixo NEXT_PUBLIC_ para chegar ao navegador.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:voce@exemplo.com"

# Segredo para proteger o endpoint de cron dos lembretes.
CRON_SECRET="troque-por-uma-string-aleatoria"
